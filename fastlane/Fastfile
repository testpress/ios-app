require 'json'

default_platform(:ios)
FASTFILE_DIR = File.expand_path(File.dirname(__FILE__))
ROOT_DIR     = File.expand_path("..", FASTFILE_DIR)
PROJECT_PATH = File.join(ROOT_DIR, "ios-app.xcodeproj")

begin
  require 'dotenv'
  Dotenv.load(File.join(ROOT_DIR, ".env"), File.join(FASTFILE_DIR, ".env"))
rescue LoadError
end

desc "Build customized app for an institute"
lane :build_app_files do |params|
  config = get_ios_app_config(subdomain: params[:subdomain])
  config = prepare_project_config(config: config, fastlane_dir: FASTFILE_DIR)
  rebrand(config: config)
end

lane :release_update_to do |params|
  if params[:subdomain] == "all"
    fetch_subdomains.each do |subdomain|
      release_update(subdomain: subdomain) rescue UI.error("Failed for #{subdomain}")
    end
  else
    release_update(subdomain: params[:subdomain])
  end
end

desc "Release updates"
private_lane :release_update do |params|
  config = update_ios_app_version(
    subdomain:    params[:subdomain],
    version:      params[:version],
    version_code: params[:version_code]
  )
  config = prepare_project_config(config: config, fastlane_dir: FASTFILE_DIR)
  rebrand(config: config)
  archive_and_upload(config: config)
end

private_lane :rebrand do |params|
  config = params[:config]
  sh("cp '#{File.expand_path(config['google_plist_path'], ROOT_DIR)}' '#{File.join(ROOT_DIR, 'ios-app', 'GoogleService-Info.plist')}'")
  customize_ios_app(config: config, fastlane_dir: FASTFILE_DIR)
end

private_lane :archive_and_upload do |params|
  config       = params[:config]
  scheme       = config["xcode_scheme"] || "Testpress.in"
  archive_path = File.join(ROOT_DIR, "build", "#{scheme}.xcarchive")

  api_key = app_store_connect_api_key(
    key_id:       config["api_key_id"],
    issuer_id:    config["api_key_issuer"],
    key_filepath: File.expand_path(config["api_key_path"], ROOT_DIR)
  )

  get_provisioning_profile(
    app_identifier: config["bundle_identifier"],
    api_key:        api_key,
    force:          true
  )

  # Target-specific patch right before build
  customize_ios_app(
    config:               config,
    fastlane_dir:         FASTFILE_DIR,
    provisioning_profile: lane_context[SharedValues::SIGH_UDID]
  )

  derived_data_path = "./DerivedData_#{scheme.gsub(' ', '_')}"
  clear_derived_data(derived_data_path: derived_data_path)

  build_app(
    project:           PROJECT_PATH,
    scheme:            scheme,
    configuration:     "Release",
    skip_package_dependencies_resolution: false,
    export_method:     "app-store",
    export_options: {
      signingStyle: "manual",
      provisioningProfiles: {
        config["bundle_identifier"] => lane_context[SharedValues::SIGH_UDID]
      }
    },
    clean:             true,
    derived_data_path: derived_data_path,
    archive_path:      archive_path,
    xcargs:            "COMPILER_INDEX_STORE_ENABLE=NO"
  )

  ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH]
  UI.user_error!("IPA not found after build.") unless ipa_path && File.exist?(ipa_path)

  upload_to_testflight(
    api_key:                           api_key,
    ipa:                               ipa_path,
    skip_waiting_for_build_processing: false,
    distribute_external:               false,
    notify_external_testers:           false
  )
end
